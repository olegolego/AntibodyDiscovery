# Application
APP_ENV=development
SECRET_KEY=change-me-in-production

# Database (SQLite for local dev; swap to postgresql+asyncpg://... for production)
DATABASE_URL=sqlite+aiosqlite:///./protein_design.db

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Artifact Storage
STORAGE_BACKEND=local         # local | s3 | gcs
LOCAL_ARTIFACT_DIR=./artifacts

# AWS S3 (when STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_ARTIFACT_BUCKET=

# GCS (when STORAGE_BACKEND=gcs)
GOOGLE_APPLICATION_CREDENTIALS=
GCS_ARTIFACT_BUCKET=

# Tool endpoints (override per tool)
ALPHAFOLD_URL=http://localhost:8001
RFDIFFUSION_URL=http://localhost:8002
PROTEINMPNN_URL=http://localhost:8003
ESMFOLD_URL=http://localhost:8004
ABMAP_URL=http://localhost:8005
